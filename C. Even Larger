        // Function to compute GCD of two numbers
        public static long gcd(long a, long b) {
            while (b != 0) {
                long temp = b;
                b = a % b;
                a = temp;
            }
            return a;
        }



        //  Binary Exponentiation (modular fast power)
        static long binPow(long a, int b) {
            long res = 1;
            while (b > 0) {
                if ((b & 1) == 1) res = res * a % mod;
                a = a * a % mod;
                b >>= 1;
            }
            return res;
        }

